/* ================= VARIABLES Y CONFIGURACIÓN GENERAL ================= */
:root {
    --bg-color: #111111;       /* Fondo oscuro elegante */
    --card-bg: #1a1a1a;       /* Fondo de tarjetas de producto */
    --accent-gold: #d4af37;   /* Dorado basado en el logo */
    --text-light: #f5f5f5;    /* Blanco texturizado */
    --text-muted: #aaaaaa;    /* Gris para descripciones */
    --font-main: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-color);
    color: var(--text-light);
    font-family: var(--font-main);
    overflow-x: hidden;
    line-height: 1.6;
}

/* ================= ENCABEZADO / LOGO ================= */
.main-header {
    width: 100%;
    display: flex;
    justify-content: center;
    background-color: #000000;
}

.logo-fullwidth {
    width: 100%;
    max-height: auto;
    object-fit: cover;
    display: block;
}

/* ================= CONTENEDOR DE SECCIONES (GRID) ================= */
.catalog-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

.catalog-section {
    cursor: pointer;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
}

.catalog-section:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(212, 175, 55, 0.2);
}

.image-wrapper {
    position: relative;
    width: 100%;
    height: 400px; /* Altura fija visualmente atractiva para las portadas */
}

.image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.catalog-section:hover .image-wrapper img {
    transform: scale(1.05);
}

/* Superposición de texto en las portadas */
.section-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
    padding: 30px 20px;
    text-align: center;
}

.section-overlay h2 {
    color: var(--text-light);
    font-size: 1.8rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-bottom: 2px solid var(--accent-gold);
    display: inline-block;
    padding-bottom: 5px;
}

/* ================= CUADROS DE DIÁLOGO (MODALES) ================= */
.modal {
    display: none; /* Oculto por defecto */
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(5px);
    overflow-y: auto;
    padding: 40px 10px;
}

.modal-content {
    background-color: var(--card-bg);
    margin: auto;
    padding: 30px;
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 12px;
    width: 90%;
    max-width: 1000px;
    position: relative;
    box-shadow: 0 5px 30px rgba(0,0,0,0.7);
    animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
}

.close-btn {
    position: absolute;
    top: 15px;
    right: 20px;
    color: var(--text-muted);
    font-size: 35px;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s;
}

.close-btn:hover {
    color: var(--accent-gold);
}

.modal-content h2 {
    color: var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 5px;
}

.modal-subtitle {
    color: var(--text-muted);
    margin-bottom: 25px;
    font-style: italic;
}

/* Grid interna de productos */
.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.product-card-placeholder {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px;
    color: var(--text-muted);
    border: 1px dashed rgba(212, 175, 55, 0.2);
}

/* ================= BOTÓN FLOTANTE WHATSAPP ================= */
.whatsapp-float {
    position: fixed;
    width: 60px;
    height: 60px;
    bottom: 30px;
    right: 30px;
    background-color: #25d366;
    color: #fff;
    border-radius: 50px;
    text-align: center;
    font-size: 35px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.3s ease, background-color 0.3s ease;
}

.whatsapp-float:hover {
    transform: scale(1.1);
    background-color: #128c7e;
}

/* Responsividad para móviles */
@media (max-width: 600px) {
    .catalog-container {
        grid-template-columns: 1fr;
        padding: 0 15px;
    }
    .image-wrapper {
        height: 300px;
    }
    .whatsapp-float {
        bottom: 20px;
        right: 20px;
        width: 50px;
        height: 50px;
        font-size: 28px;
    }
}
// Función para abrir la ventana modal específica
function openModal(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
        modal.style.display = "block";
        document.body.style.overflow = "hidden"; // Evita el scroll del fondo
    }
}

// Función para cerrar la ventana modal específica
function closeModal(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
        modal.style.display = "none";
        document.body.style.overflow = "auto"; // Restaura el scroll del fondo
    }
}

// Cerrar el modal automáticamente si el usuario hace clic fuera de la caja de contenido
window.onclick = function(event) {
    if (event.target.classList.contains('modal')) {
        event.target.style.display = "none";
        document.body.style.overflow = "auto";
    }
}
